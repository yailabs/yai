{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "law/grammar/schema/law_publish_index.v1",
  "title": "law_publish_index.v1",
  "description": "Publish index for law surfaces",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "required": [
    "kind",
    "version",
    "entries"
  ],
  "additionalProperties": true
}
