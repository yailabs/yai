{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "law/grammar/schema/effective_stack.v1",
  "title": "effective_stack.v1",
  "description": "Resolved policy stack",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "stack_id": {
      "type": "string"
    },
    "domain_id": {
      "type": "string"
    },
    "foundation_layers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "domain_layers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compliance_layers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "overlay_layers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "precedence_trace": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resolved_effect_space": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "kind",
    "version",
    "stack_id",
    "domain_id",
    "resolved_effect_space"
  ],
  "additionalProperties": true
}
