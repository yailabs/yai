{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "law/grammar/schema/runtime_entrypoint.v1",
  "title": "runtime_entrypoint.v1",
  "description": "Unified runtime consumption entrypoint contract",
  "type": "object",
  "required": ["kind", "version", "runtime_contract", "entrypoints"],
  "properties": {
    "kind": {
      "type": "string",
      "const": "runtime.entrypoints"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "runtime_contract": {
      "type": "object",
      "required": ["topology_target", "binding_model", "canonical_runtime_families"],
      "properties": {
        "topology_target": {
          "type": "string",
          "const": "unified-runtime-v1"
        },
        "binding_model": {
          "type": "string",
          "enum": ["workspace-first"]
        },
        "canonical_runtime_families": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["core", "exec", "data", "graph", "knowledge", "law", "platform", "protocol", "support"]
          },
          "minItems": 5
        },
        "legacy_subsystem_aliases": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "entrypoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "entrypoint_id",
          "law_manifest_ref",
          "classification_ref",
          "families_ref",
          "specializations_ref",
          "domains_ref",
          "compliance_ref",
          "governance_attachability_constraints_ref",
          "runtime_family_targets",
          "workspace_binding_required",
          "disallowed_subsystem_targets"
        ],
        "properties": {
          "entrypoint_id": {"type": "string"},
          "law_manifest_ref": {"type": "string"},
          "classification_ref": {"type": "string"},
          "families_ref": {"type": "string"},
          "specializations_ref": {"type": "string"},
          "domains_ref": {"type": "string"},
          "compliance_ref": {"type": "string"},
          "customer_policy_pack_index_ref": {"type": "string"},
          "governance_attachability_constraints_ref": {"type": "string"},
          "resolution_order_ref": {"type": "string"},
          "compliance_resolution_order_ref": {"type": "string"},
          "compatibility_ref": {"type": "string"},
          "entry_surface_model": {
            "type": "string",
            "enum": ["unified-runtime-family-gated"]
          },
          "attachability_model": {
            "type": "string",
            "enum": ["workspace-bound-governance-attachability"]
          },
          "workspace_binding_required": {"type": "boolean"},
          "runtime_family_targets": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["core", "exec", "data", "graph", "knowledge", "law", "platform", "protocol", "support"]
            },
            "minItems": 1
          },
          "disallowed_subsystem_targets": {
            "type": "array",
            "items": {"type": "string", "enum": ["brain", "mind"]}
          },
          "overlays_ref": {
            "type": "object",
            "properties": {
              "regulatory": {"type": "string"},
              "sector": {"type": "string"},
              "contextual": {"type": "string"}
            },
            "additionalProperties": true
          },
          "legacy_bridge": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
