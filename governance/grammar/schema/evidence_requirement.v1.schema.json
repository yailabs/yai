{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "law/grammar/schema/evidence_requirement.v1",
  "title": "evidence_requirement.v1",
  "description": "Evidence requirement",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "evidence_type": {
      "type": "string"
    },
    "required_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "retention_hint": {
      "type": "string"
    },
    "trace_links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "kind",
    "version",
    "evidence_type",
    "required_fields"
  ],
  "additionalProperties": true
}
