{
  "kind": "publish.index",
  "version": "v4",
  "targets": [
    {
      "target": "runtime-embedded",
      "profile": "runtime-consumer.v4",
      "includes": [
        "classification",
        "control-families",
        "domain-specializations",
        "overlays/regulatory",
        "overlays/sector",
        "overlays/contextual",
        "manifests"
      ],
      "generated": [
        "generated/domains.index.json",
        "generated/compliance.index.json",
        "generated/runtime-resolution-view.json",
        "generated/export.summary.json",
        "generated/compatibility.summary.json"
      ],
      "excludes": [
        "**/*.md",
        "archive_tmp/**",
        "docs/**",
        "authority/**",
        "foundation/**",
        "formal/**",
        "tools/**",
        "contracts/**",
        "registry/**"
      ]
    },
    {
      "target": "docs-reference",
      "includes": [
        "docs/architecture",
        "docs/authoring",
        "docs/references"
      ]
    },
    {
      "target": "audit-reference",
      "includes": [
        "contracts",
        "registry",
        "formal"
      ]
    }
  ]
}
