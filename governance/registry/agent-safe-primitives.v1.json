{
  "kind": "agent_safe_primitives_catalog",
  "version": "v1",
  "capability_classes": [
    "read_only",
    "propose_only",
    "validate_only",
    "review_assist",
    "request_transition",
    "human_confirmation_required",
    "system_forbidden"
  ],
  "primitives": [
    {
      "id": "gov.source.inspect",
      "kind": "read_only",
      "capability_class": "read_only",
      "invocation": "yai law gov source inspect <source-id>",
      "requires_human_confirmation": false,
      "lifecycle_guard": "none",
      "allowed_for_agent": true,
      "no_skip_boundary": "read_only_no_state_change",
      "notes": "Safe inspect of intake source.",
      "runtime_family_owner": "data",
      "runtime_binding_model": "workspace-first",
      "workspace_binding_required": true
    },
    {
      "id": "gov.parse",
      "kind": "proposal",
      "capability_class": "propose_only",
      "invocation": "yai law gov parse <source-id>",
      "requires_human_confirmation": false,
      "lifecycle_guard": "candidate_not_created",
      "allowed_for_agent": true,
      "no_skip_boundary": "parse_before_build",
      "notes": "Agent may propose parse but cannot mark approved.",
      "runtime_family_owner": "core",
      "runtime_binding_model": "workspace-first",
      "workspace_binding_required": true
    },
    {
      "id": "gov.build.candidate",
      "kind": "proposal",
      "capability_class": "propose_only",
      "invocation": "yai law gov build <normalized-id>",
      "requires_human_confirmation": false,
      "lifecycle_guard": "normalized_required",
      "allowed_for_agent": true,
      "no_skip_boundary": "candidate_not_operational",
      "notes": "Build never implies approval.",
      "runtime_family_owner": "core",
      "runtime_binding_model": "workspace-first",
      "workspace_binding_required": true
    },
    {
      "id": "gov.review.submit",
      "kind": "controlled_transition",
      "capability_class": "review_assist",
      "invocation": "yai law gov review submit <candidate-id>",
      "requires_human_confirmation": true,
      "lifecycle_guard": "review_readiness_required",
      "allowed_for_agent": true,
      "no_skip_boundary": "candidate_to_under_review_only",
      "notes": "Agent can request submission; readiness gates enforced.",
      "runtime_family_owner": "core",
      "runtime_binding_model": "workspace-first",
      "workspace_binding_required": true
    },
    {
      "id": "gov.review.approve",
      "kind": "controlled_transition",
      "capability_class": "human_confirmation_required",
      "invocation": "yai law gov review approve <candidate-id>",
      "requires_human_confirmation": true,
      "lifecycle_guard": "under_review_required",
      "allowed_for_agent": false,
      "no_skip_boundary": "no_direct_candidate_to_approved",
      "notes": "Reserved for human approval authority.",
      "runtime_family_owner": "core",
      "runtime_binding_model": "workspace-first",
      "workspace_binding_required": true
    },
    {
      "id": "workspace.policy.dry_run",
      "kind": "validation",
      "capability_class": "validate_only",
      "invocation": "yai ws policy dry-run <object-id>",
      "requires_human_confirmation": false,
      "lifecycle_guard": "object_resolution_required",
      "allowed_for_agent": true,
      "no_skip_boundary": "dry_run_before_attach",
      "notes": "Preview-only; no activation.",
      "runtime_family_owner": "core",
      "runtime_binding_model": "workspace-first",
      "workspace_binding_required": true
    },
    {
      "id": "workspace.policy.attach",
      "kind": "operational_apply",
      "capability_class": "request_transition",
      "invocation": "yai ws policy attach <object-id>",
      "requires_human_confirmation": true,
      "lifecycle_guard": "approved_and_apply_eligible_required",
      "allowed_for_agent": false,
      "no_skip_boundary": "apply_gated_by_lifecycle",
      "notes": "Runtime blocks enterprise objects not review-approved.",
      "runtime_family_owner": "core",
      "runtime_binding_model": "workspace-first",
      "workspace_binding_required": true
    },
    {
      "id": "gov.force.approve",
      "kind": "forbidden_direct",
      "capability_class": "system_forbidden",
      "invocation": "forbidden",
      "requires_human_confirmation": true,
      "lifecycle_guard": "forbidden",
      "allowed_for_agent": false,
      "no_skip_boundary": "forbidden_transition",
      "notes": "No direct force-approve bypass exists.",
      "runtime_family_owner": "core",
      "runtime_binding_model": "workspace-first",
      "workspace_binding_required": true
    }
  ]
}
