{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "control/assurance/model/schema/formal_module.v1.schema.json",
  "title": "Formal Module Descriptor v1",
  "type": "object",
  "required": ["id", "module", "domain_links", "invariants"],
  "properties": {
    "id": {"type": "string", "pattern": "^FM-[0-9]{3}$"},
    "module": {"type": "string", "pattern": "^control/assurance/modules/[a-z0-9_]+\\.tla$"},
    "domain_links": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}
