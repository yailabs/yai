{
  "kind": "runtime.entrypoints",
  "version": "v4",
  "entrypoints": [
    {
      "entrypoint_id": "default-runtime",
      "law_manifest_ref": "manifests/law.manifest.json",
      "classification_ref": "classification/classification-map.json",
      "families_ref": "control-families/index/families.index.json",
      "specializations_ref": "domain-specializations/index/specializations.index.json",
      "domains_ref": "domain-specializations/index/specializations.index.json",
      "compliance_ref": "overlays/regulatory/index/regulatory.index.json",
      "customer_policy_pack_index_ref": "manifests/customer-policy-packs.index.json",
      "governance_attachability_constraints_ref": "manifests/governance-attachability.constraints.v1.json",
      "resolution_order_ref": "manifests/domain-resolution-order.json",
      "compliance_resolution_order_ref": "manifests/compliance-resolution-order.json",
      "compatibility_ref": "manifests/compatibility.matrix.json",
      "overlays_ref": {
        "regulatory": "overlays/regulatory/index/regulatory.index.json",
        "sector": "overlays/sector/index/sector.index.json",
        "contextual": "overlays/contextual/index/contextual.index.json"
      },
      "legacy_bridge": {
        "seed_root": "transitional/domain-family-seed/",
        "enabled": false,
        "mode": "opt-in-compat-only"
      },
      "entry_surface_model": "unified-runtime-family-gated",
      "attachability_model": "workspace-bound-governance-attachability",
      "workspace_binding_required": true,
      "runtime_family_targets": [
        "core",
        "exec",
        "data",
        "graph",
        "knowledge"
      ],
      "disallowed_subsystem_targets": [
        "brain",
        "mind"
      ],
      "source_plane_operations": [
        "enroll",
        "attach",
        "emit",
        "status"
      ],
      "source_attachment_governance_ref": "manifests/governance-attachability.constraints.v1.json#constraints.source_attachment_governance",
      "source_plane_truth_model": {
        "owner_runtime_truth": "canonical",
        "source_plane_role": "subordinate-edge-runtime",
        "source_evidence_semantics": "candidate-before-owner-resolution",
        "delegation_authority_model": "owner-issued-scope-limited-revocable",
        "delegation_non_sovereign": true,
        "edge_enforcement_model": "delegated-owner-scoped",
        "edge_enforcement_non_sovereign": true,
        "edge_enforcement_hold_escalation": "supported_by_contract"
      },
      "secure_peering_plane": {
        "required_for_non_local_networks": true,
        "recommended_model": "private_overlay_wireguard_or_equivalent",
        "owner_remote_peer_ingress_required": true,
        "application_protocol_role": "application-layer-only",
        "transport_security_role": "separate-secure-peering-layer"
      },
      "global_to_edge_policy_hierarchy_ref": "manifests/governance-attachability.constraints.v1.json#constraints.global_to_edge_policy_hierarchy",
      "delegated_edge_enforcement_ref": "manifests/governance-attachability.constraints.v1.json#constraints.delegated_edge_enforcement",
      "edge_binding_action_point_model_ref": "manifests/governance-attachability.constraints.v1.json#constraints.edge_binding_action_point_model"
    }
  ],
  "runtime_contract": {
    "topology_target": "unified-runtime-v1",
    "binding_model": "workspace-first",
    "canonical_runtime_families": [
      "core",
      "exec",
      "data",
      "graph",
      "knowledge",
      "law",
      "platform",
      "protocol",
      "support"
    ],
    "legacy_subsystem_aliases": {
      "brain": "deprecated-non-canonical",
      "mind": "deprecated-non-canonical"
    }
  }
}
