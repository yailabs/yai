{
  "kind": "governance-attachability-constraints",
  "version": "v2",
  "binding_model": "workspace-first",
  "constraints": {
    "allowed_by_kind": {
      "compliance_module": [
        "stack",
        "policy-composition"
      ],
      "overlay": [
        "overlay-stack",
        "policy-composition"
      ],
      "customer_policy_pack": [
        "workspace-attach",
        "runtime-entrypoint"
      ],
      "enterprise_custom_governance_object": [
        "workspace_attach",
        "organization_default",
        "runtime_entrypoint"
      ],
      "specialization_policy_pack": [
        "domain-set",
        "policy-resolution-anchor"
      ],
      "template_object": [
        "none"
      ]
    },
    "runtime_consumable_by_kind": {
      "compliance_module": true,
      "overlay": true,
      "customer_policy_pack": true,
      "enterprise_custom_governance_object": true,
      "specialization_policy_pack": true,
      "template_object": false
    },
    "cli_discoverable_by_kind": {
      "compliance_module": true,
      "overlay": true,
      "customer_policy_pack": true,
      "enterprise_custom_governance_object": true,
      "specialization_policy_pack": true,
      "template_object": false
    },
    "precedence_classes": {
      "compliance_module": [
        "compliance-layer"
      ],
      "overlay": [
        "overlay-regulatory",
        "overlay-sector",
        "overlay-contextual"
      ],
      "customer_policy_pack": [
        "specialization+compliance+overlays+customer-pack",
        "specialization+contextual-overlays+customer-pack"
      ],
      "enterprise_custom_governance_object": [
        "specialization+compliance+overlays+customer-pack+enterprise-object",
        "specialization+contextual-overlays+customer-pack+enterprise-object"
      ],
      "specialization_policy_pack": [
        "specialization-baseline"
      ],
      "template_object": [
        "non-operational-template"
      ]
    },
    "workspace_apply_states": [
      "candidate_only",
      "approved_not_attached",
      "attached_inactive",
      "attached_active",
      "attach_rejected",
      "detached",
      "superseded"
    ],
    "workspace_compatibility_results": [
      "eligible",
      "eligible_with_warnings",
      "ineligible",
      "dry_run_passed",
      "dry_run_failed",
      "conflict_blocking"
    ],
    "disallowed_subsystem_targets": [
      "brain",
      "mind"
    ],
    "canonical_attachment_modes": [
      "stack",
      "policy-composition",
      "overlay-stack",
      "workspace-attach",
      "runtime-entrypoint",
      "domain-set",
      "policy-resolution-anchor",
      "organization-default",
      "none"
    ],
    "attachment_mode_aliases": {
      "workspace_attach": "workspace-attach",
      "runtime_entrypoint": "runtime-entrypoint",
      "organization_default": "organization-default"
    },
    "runtime_family_targets_by_kind": {
      "compliance_module": [
        "core",
        "data"
      ],
      "overlay": [
        "core",
        "data",
        "graph"
      ],
      "customer_policy_pack": [
        "core",
        "exec",
        "data",
        "graph",
        "knowledge"
      ],
      "enterprise_custom_governance_object": [
        "core",
        "exec",
        "data",
        "graph",
        "knowledge"
      ],
      "specialization_policy_pack": [
        "core",
        "exec",
        "data",
        "graph",
        "knowledge"
      ],
      "template_object": [
        "law"
      ]
    },
    "workspace_binding_required_by_kind": {
      "compliance_module": false,
      "overlay": false,
      "customer_policy_pack": true,
      "enterprise_custom_governance_object": true,
      "specialization_policy_pack": true,
      "template_object": false
    },
    "source_attachment_governance": {
      "governable_entities": [
        "source_node",
        "source_binding",
        "source_action_point",
        "source_asset",
        "source_acquisition_event",
        "source_evidence_candidate"
      ],
      "attachment_decisions": [
        "allow",
        "review",
        "deny"
      ],
      "source_trust_levels": [
        "trusted",
        "review_required",
        "restricted"
      ],
      "minimum_provenance_fields": [
        "source_node_id",
        "source_binding_id",
        "source_asset_id",
        "acquisition_event_id",
        "observed_at"
      ],
      "required_evidence_expectations": [
        "source_owner_link",
        "source_provenance_bundle",
        "acquisition_event_chain"
      ],
      "workspace_binding_required": true,
      "notes": "Distributed source attachment is governed before owner-side canonicalization.",
      "delegation_model": {
        "edge_role": "subordinate_edge_runtime",
        "policy_origin": "owner_workspace_global_policy_plane",
        "owner_issued_only": true,
        "scope_limited": true,
        "revocable": true,
        "snapshot_non_sovereign": true,
        "grant_non_sovereign": true,
        "capability_envelope_non_sovereign": true,
        "stale_state_policy": "reduce_local_autonomy",
        "delegated_enforcement_non_sovereign": true,
        "owner_final_authority_required": true
      }
    },
    "secure_peering_assumptions": {
      "non_local_source_attachment_requires_secure_peering": true,
      "accepted_peering_models": [
        "private_overlay_wireguard_or_equivalent"
      ],
      "disallowed_model_examples": [
        "public_unprotected_owner_socket"
      ],
      "note": "Attachment governance does not waive transport security requirements."
    },
    "global_to_edge_policy_hierarchy": {
      "workspace_global_policy_plane": {
        "authority": "sovereign_owner_runtime",
        "truth_classes": [
          "policy_truth",
          "graph_truth",
          "conflict_truth",
          "canonical_state_truth"
        ]
      },
      "delegated_edge_policy_plane": {
        "authority": "owner_issued_delegation_only",
        "artifacts": [
          "policy_snapshot",
          "grant",
          "capability_envelope"
        ],
        "non_sovereign": true
      },
      "edge_execution_observation_plane": {
        "authority": "subordinate_runtime_execution_only",
        "allowed_baseline": [
          "observation",
          "action_mediation",
          "delegated_enforcement",
          "spool_retry_health"
        ]
      },
      "precedence_rules": {
        "global_overrides_delegated": true,
        "delegated_cannot_expand_scope": true,
        "ambiguity_falls_back_to_owner": true,
        "stale_or_missing_delegation_reduces_autonomy": true
      }
    },
    "delegated_edge_enforcement": {
      "enforcement_modes": [
        "observe_only",
        "post_event_local_enforcement",
        "preventive_local_enforcement",
        "escalated_enforcement"
      ],
      "local_outcomes": [
        "observe_only",
        "allow",
        "block",
        "hold",
        "execute",
        "escalate",
        "defer",
        "deny_due_to_missing_scope",
        "deny_due_to_expired_grant"
      ],
      "authority_rule": "delegated_execution_not_sovereign_adjudication",
      "requires_valid_owner_scope": true,
      "allows_hold_and_escalation": true,
      "stale_or_missing_grant_behavior": {
        "autonomy_change": "reduce_only",
        "fallback_modes": [
          "observe_only",
          "hold",
          "escalate"
        ],
        "must_not_expand_local_authority": true
      }
    },
    "edge_binding_action_point_model": {
      "binding_kinds": [
        "observational",
        "mediable"
      ],
      "scope_model": [
        "binding_scope",
        "observation_scope",
        "mediation_scope",
        "enforcement_scope"
      ],
      "action_point_entity": "source_action_point",
      "controllability_states": [
        "observe_only",
        "delegated_candidate",
        "delegated_active",
        "escalation_required"
      ],
      "non_sovereign_rule": "binding_and_action_point_control_is_delegated_not_sovereign"
    }
  },
  "topology_target": "unified-runtime-v1",
  "canonical_runtime_families": [
    "core",
    "exec",
    "data",
    "graph",
    "knowledge",
    "law",
    "platform",
    "protocol",
    "support"
  ]
}
