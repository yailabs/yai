# =============================================================================
# YAI — Canonical .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# OS / editor
# -----------------------------------------------------------------------------
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# Optional: local editor settings (keep templates tracked elsewhere if needed)
# !.vscode/*.example

# -----------------------------------------------------------------------------
# Secrets / local env
# -----------------------------------------------------------------------------
.env
.env.*
.envrc
*.key
*.pem
*.cert
*.crt
*.token
*.secret
secrets.*
.secrets/

# -----------------------------------------------------------------------------
# Rust / Cargo (workspace)
# -----------------------------------------------------------------------------
target/
**/target/
**/*.rs.bk

# NOTE: root Cargo.lock is tracked for deterministic builds
# Cargo.lock

# -----------------------------------------------------------------------------
# Canonical build + staging outputs
# -----------------------------------------------------------------------------
build/
dist/
out/
artifacts/
states/
cache/
tmp/
*.tmp
*.out
*.log
.pr/

mind/build/
mind/dist/

# Keep doxygen output out of VCS
dist/docs/doxygen/

# -----------------------------------------------------------------------------
# Tooling / generated artifacts
# -----------------------------------------------------------------------------
compile_commands.json
**/compile_commands.json
engine/compile_commands.json

# -----------------------------------------------------------------------------
# Next.js / Node (some repos may vendor these; ignore by default)
# -----------------------------------------------------------------------------
.next/
node_modules/

# -----------------------------------------------------------------------------
# C/C++ build artifacts (from core planes)
# -----------------------------------------------------------------------------
*.o
*.a
*.so
*.d
*.dSYM

# -----------------------------------------------------------------------------
# YAI local runtime artifacts
# -----------------------------------------------------------------------------
/.yai/

# -----------------------------------------------------------------------------
# Formal tooling scratch (legacy paths; keep ignored)
# -----------------------------------------------------------------------------
governance/control/assurance/states/
governance/control/assurance/*.fp
governance/control/assurance/*.st
governance/control/assurance/*.toolbox/

# -----------------------------------------------------------------------------
# Local-only drafts
# -----------------------------------------------------------------------------
docs/60-validation/proof/.private/
docs/60-validation/audits/.private/
tools/python/**/__pycache__/
tools/python/**/.pytest_cache/
tools/python/**/.mypy_cache/
tools/python/**/.ruff_cache/
tools/python/**/tests/

# Local data that must not be committed (decide later if canonical)
data/global/
tools/lib/

# If prompts.csv is canonical, REMOVE this line and commit the file instead.
data/datasets/global-stress/v1/prompts.csv