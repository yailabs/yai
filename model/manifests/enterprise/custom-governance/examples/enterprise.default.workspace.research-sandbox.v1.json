    ],
    "overlay_refs": [
      "packages/contextual/workspace/manifest.v1.json",
      "packages/contextual/session/manifest.v1.json"
    ]
  },
  "policy_refs": [
    "specializations/scientific/parameter-governance/policy-pack.json",
    "specializations/scientific/result-publication-control/policy-pack.json",
