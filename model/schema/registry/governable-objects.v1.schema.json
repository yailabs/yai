{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai-governance:model/schema/registry/governable_objects.v1.schema.json",
  "title": "YAI Governable Objects Registry v1",
  "type": "object",
  "required": ["kind", "version", "generated_by", "objects"],
  "properties": {
    "kind": {
      "const": "governable_objects_registry"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "generated_by": {
      "type": "string",
      "minLength": 1
    },
    "objects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/object"
      }
    }
  },
  "$defs": {
    "object": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "name",
        "status",
        "scope_targets",
        "attachment_modes",
        "source_ref",
        "manifest_ref",
        "compatibility_ref",
        "precedence_class",
        "runtime_consumable",
        "cli_discoverable",
        "experimental",
        "deprecated",
        "dependencies",
        "conflicts_with"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 2
        },
        "kind": {
          "type": "string",
          "enum": [
            "compliance_module",
            "overlay",
            "customer_policy_pack",
            "enterprise_custom_governance_object",
            "specialization_policy_pack",
            "template_object"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "scope_targets": {
          "type": "object",
          "properties": {
            "organization_ids": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "workspace_ids": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "environment_classes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "session_scope": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "domain_targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "family_targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "specialization_targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "attachment_modes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "manifest_ref": {
          "type": "string",
          "minLength": 1
        },
        "compatibility_ref": {
          "type": "string",
          "minLength": 1
        },
        "precedence_class": {
          "type": "string",
          "minLength": 1
        },
        "runtime_consumable": {
          "type": "boolean"
        },
        "cli_discoverable": {
          "type": "boolean"
        },
        "experimental": {
          "type": "boolean"
        },
        "deprecated": {
          "type": "boolean"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "conflicts_with": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "runtime_family_targets": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "core",
              "exec",
              "data",
              "graph",
              "knowledge",
              "governance",
              "platform",
              "protocol",
              "support"
            ]
          }
        },
        "runtime_binding_model": {
          "type": "string",
          "enum": ["workspace-first", "global-baseline", "authoring-only"]
        },
        "topology_target": {
          "type": "string",
          "enum": ["unified-runtime-v1"]
        },
        "execution_family_owner": {
          "type": "string",
          "enum": ["core", "exec", "none"]
        },
        "knowledge_support_family": {
          "type": "string",
          "enum": ["knowledge", "none"]
        },
        "graph_family_owner": {
          "type": "string",
          "enum": ["graph", "none"]
        },
        "data_family_owner": {
          "type": "string",
          "enum": ["data", "none"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
