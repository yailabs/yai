{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "governance/grammar/model/schema/enterprise_custom_governance.v1",
  "title": "enterprise_custom_governance.v1",
  "description": "Canonical enterprise custom governance object manifest",
  "type": "object",
  "properties": {
    "kind": {
      "const": "enterprise_custom_governance"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "id": {
      "type": "string",
      "minLength": 3
    },
    "name": {
      "type": "string",
      "minLength": 3
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "object",
      "properties": {
        "organization_id": {"type": "string"},
        "owner_team": {"type": "string"},
        "approver_role": {"type": "string"}
      },
      "required": ["organization_id"],
      "additionalProperties": true
    },
    "organization_scope": {
      "type": "object",
      "properties": {
        "organization_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "environment_classes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "session_scope": {"type": "string"}
      },
      "required": ["organization_ids"],
      "additionalProperties": true
    },
    "scope_targets": {
      "type": "array",
      "items": {"type": "string"}
    },
    "domain_targets": {
      "type": "array",
      "items": {"type": "string"}
    },
    "specialization_targets": {
      "type": "array",
      "items": {"type": "string"}
    },
    "source_inputs": {
      "type": "object",
      "properties": {
        "customer_policy_pack_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "compliance_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "overlay_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "specialization_policy_refs": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "policy_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "overlay_refs": {
      "type": "object",
      "properties": {
        "regulatory": {
          "type": "array",
          "items": {"type": "string"}
        },
        "sector": {
          "type": "array",
          "items": {"type": "string"}
        },
        "contextual": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "authority_profile": {
      "type": "object",
      "additionalProperties": true
    },
    "evidence_profile": {
      "type": "object",
      "additionalProperties": true
    },
    "precedence_mode": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["template", "example", "candidate", "approved", "applied", "deprecated"]
    },
    "review_state": {
      "type": "string",
      "enum": ["draft", "in_review", "approved", "rejected", "waived"]
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "governance_range": {"type": "string"},
        "runtime_targets": {
          "type": "array",
          "items": {"type": "string"}
        },
        "export_profiles": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "required": ["governance_range", "runtime_targets"],
      "additionalProperties": true
    },
    "apply_modes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["scope_attach", "organization_default", "runtime_entrypoint"]
      },
      "minItems": 1
    },
    "runtime_consumable": {
      "type": "boolean"
    },
    "runtime_entrypoint_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "provenance": {
      "type": "object",
      "properties": {
        "source_type": {"type": "string"},
        "source_ref": {"type": "string"},
        "created_by": {"type": "string"},
        "updated_by": {"type": "string"}
      },
      "required": ["source_type", "source_ref"],
      "additionalProperties": true
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "kind",
    "schema_version",
    "id",
    "name",
    "version",
    "owner",
    "organization_scope",
    "scope_targets",
    "domain_targets",
    "source_inputs",
    "policy_refs",
    "overlay_refs",
    "authority_profile",
    "evidence_profile",
    "precedence_mode",
    "status",
    "review_state",
    "compatibility",
    "apply_modes",
    "runtime_consumable",
    "provenance"
  ],
  "additionalProperties": true
}
