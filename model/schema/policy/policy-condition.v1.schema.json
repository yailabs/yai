{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "governance/grammar/model/schema/policy_condition.v1",
  "title": "policy_condition.v1",
  "description": "Policy condition",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "action": {
      "type": "string"
    },
    "asset": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "protocol": {
      "type": "string"
    },
    "resource": {
      "type": "string"
    },
    "authority": {
      "type": "string"
    },
    "context_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "kind",
    "version",
    "action"
  ],
  "additionalProperties": true
}
