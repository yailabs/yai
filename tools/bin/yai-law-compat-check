#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$ROOT/tools/dev/resolve-law-embed.sh" || true

EMBED_ROOT="$(yai_resolve_law_embed_root "$ROOT" || true)"

python3 - "$ROOT" "${EMBED_ROOT:-}" <<'PY'
import json
import sys
from pathlib import Path

root = Path(sys.argv[1])
embed = Path(sys.argv[2]) if len(sys.argv) > 2 and sys.argv[2] else None

required = [
    "governance/manifests/law.manifest.json",
    "governance/manifests/runtime.entrypoints.json",
    "governance/manifests/publish.index.json",
    "governance/manifests/publish.layers.json",
    "governance/manifests/compatibility.matrix.json",
    "governance/manifests/domain-resolution-order.json",
    "governance/manifests/compliance-resolution-order.json",
    "governance/manifests/governance-attachability.constraints.v1.json",
    "governance/manifests/customer-policy-packs.index.json",
    "governance/manifests/enterprise-custom-governance.index.json",
]

errors = []
for rel in required:
    p = root / rel
    if not p.exists():
        errors.append(f"missing: {rel}")

for rel in [r for r in required if r.endswith(".json") and (root / r).exists()]:
    try:
        json.loads((root / rel).read_text(encoding="utf-8"))
    except Exception as exc:
        errors.append(f"invalid json: {rel} ({exc})")

manifest = root / "governance/manifests/law.manifest.json"
if manifest.exists():
    payload = json.loads(manifest.read_text(encoding="utf-8"))
    if payload.get("resolution_entrypoints_ref") != "manifests/runtime.entrypoints.json":
        errors.append("invalid resolution_entrypoints_ref in governance/manifests/law.manifest.json")

# Optional embedded bridge compatibility check.
if embed and embed.exists():
    for rel in ["manifests/publish.index.json", "manifests/publish.layers.json"]:
        if not (embed / rel).exists():
            errors.append(f"embedded bridge missing: {rel}")

if errors:
    print("governance manifest compatibility: FAIL")
    for e in errors:
        print(" -", e)
    raise SystemExit(1)

print("governance manifest compatibility: OK")
if embed and embed.exists():
    print(f"embedded bridge present: {embed}")
else:
    print("embedded bridge absent: allowed")
PY
