#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import shutil
import subprocess
import sys
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, Iterable, List, Tuple

ROOT = Path(__file__).resolve().parents[2]
INGESTION = ROOT / "governance" / "ingestion"
SOURCES_DIR = INGESTION / "sources"
PARSED_DIR = INGESTION / "parsed"
NORMALIZED_DIR = INGESTION / "normalized"
CANDIDATES_DIR = INGESTION / "candidates"
REVIEW_DIR = INGESTION / "review"
ENGINE = ROOT / "tools" / "gen" / "deterministic_governance_ingestion.py"


@dataclass
class SourceRecord:
    path: Path
    doc: Dict[str, Any]


def now_utc() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()


def read_json(path: Path) -> Dict[str, Any]:
    with path.open("r", encoding="utf-8") as f:
        return json.load(f)


def write_json(path: Path, payload: Dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("w", encoding="utf-8") as f:
        json.dump(payload, f, indent=2, ensure_ascii=True)
        f.write("\n")


def source_filename(source_id: str) -> str:
    sid = source_id.replace("/", "_")
    return f"{sid}.source.v1.json"


def safe_id(id_value: str) -> str:
    return id_value.replace("/", "_")


def review_filename(object_id: str) -> str:
    return f"{safe_id(object_id)}.review.v1.json"


def list_sources() -> List[SourceRecord]:
    selected: Dict[str, SourceRecord] = {}
    SOURCES_DIR.mkdir(parents=True, exist_ok=True)
    for p in sorted(SOURCES_DIR.glob("*.json")):
        try:
            doc = read_json(p)
        except Exception:
            continue
        if doc.get("kind") != "enterprise_governance_source":
            continue
        sid = str(doc.get("source_id", "")).strip()
        if not sid:
            continue
        rec = SourceRecord(path=p, doc=doc)
        prev = selected.get(sid)
        if prev is None:
            selected[sid] = rec
            continue
        if p.stat().st_mtime >= prev.path.stat().st_mtime:
            selected[sid] = rec
    return [selected[k] for k in sorted(selected.keys())]


def find_source_by_id(source_id: str) -> SourceRecord | None:
    for r in list_sources():
        if str(r.doc.get("source_id", "")) == source_id:
            return r
    return None


def list_parsed() -> List[Dict[str, Any]]:
    PARSED_DIR.mkdir(parents=True, exist_ok=True)
    rows: List[Dict[str, Any]] = []
    for p in sorted(PARSED_DIR.glob("*.json")):
        try:
            doc = read_json(p)
        except Exception:
            continue
        if doc.get("kind") != "governance_parsed_facts":
            continue
        rows.append({"path": p, "doc": doc})
    return rows


def find_parsed_by_source_ref(source_ref: str) -> Dict[str, Any] | None:
    for row in list_parsed():
        if str(row["doc"].get("source_ref", "")) == source_ref:
            return row
    return None


def list_normalized() -> List[Dict[str, Any]]:
    NORMALIZED_DIR.mkdir(parents=True, exist_ok=True)
    rows: List[Dict[str, Any]] = []
    for p in sorted(NORMALIZED_DIR.glob("*.json")):
        try:
            doc = read_json(p)
        except Exception:
            continue
        if doc.get("kind") != "enterprise_governance_normalized":
            continue
        rows.append({"path": p, "doc": doc})
    return rows


def find_normalized_by_id(normalized_id: str) -> Dict[str, Any] | None:
    for row in list_normalized():
        if str(row["doc"].get("normalized_id", "")) == normalized_id:
            return row
    return None


def find_normalized_by_source(source_id: str) -> Dict[str, Any] | None:
    for row in list_normalized():
        srcs = row["doc"].get("source_refs", [])
        if isinstance(srcs, list) and source_id in srcs:
            return row
    return None


def list_candidates() -> List[Dict[str, Any]]:
    CANDIDATES_DIR.mkdir(parents=True, exist_ok=True)
    rows: List[Dict[str, Any]] = []
    for p in sorted(CANDIDATES_DIR.glob("*.json")):
        try:
            doc = read_json(p)
        except Exception:
            continue
        if doc.get("kind") != "enterprise_custom_governance":
            continue
        rows.append({"path": p, "doc": doc})
    return rows


def find_candidate_by_id(candidate_id: str) -> Dict[str, Any] | None:
    for row in list_candidates():
        if str(row["doc"].get("id", "")) == candidate_id:
            return row
    return None


def default_review_state(candidate_doc: Dict[str, Any]) -> Dict[str, Any]:
    object_id = str(candidate_doc.get("id", "")).strip()
    validation_state = "valid"
    if not object_id:
        object_id = "unknown"
    return {
        "kind": "governance_review_state",
        "schema_version": "v1",
        "object_id": object_id,
        "lifecycle_state": "candidate",
        "validation_state": validation_state,
        "review_state": str(candidate_doc.get("review_state", "in_review") or "in_review"),
        "approval_state": "not_approved",
        "approval_conditions": [],
        "review_notes": [],
        "reviewed_by": None,
        "reviewed_at": None,
        "approved_by": None,
        "approved_at": None,
        "rejected_by": None,
        "rejected_at": None,
        "withdrawn_by": None,
        "withdrawn_at": None,
        "supersedes_ref": None,
        "superseded_by_ref": None,
        "status_reason": "candidate_created",
        "blockers": [],
        "warnings": [],
        "next_allowed_actions": ["review.submit", "review.withdraw", "review.inspect"],
        "updated_at": now_utc(),
    }


def review_state_path(object_id: str) -> Path:
    REVIEW_DIR.mkdir(parents=True, exist_ok=True)
    return REVIEW_DIR / review_filename(object_id)


def load_review_state(object_id: str, candidate_doc: Dict[str, Any]) -> Dict[str, Any]:
    p = review_state_path(object_id)
    if p.exists():
        return read_json(p)
    return default_review_state(candidate_doc)


def save_review_state(state_doc: Dict[str, Any]) -> Path:
    object_id = str(state_doc.get("object_id", "")).strip()
    if not object_id:
        raise ValueError("object_id required in review state")
    p = review_state_path(object_id)
    write_json(p, state_doc)
    return p


def call_engine(*args: str) -> int:
    cmd = ["python3", str(ENGINE), *args]
    return subprocess.call(cmd, cwd=str(ROOT))


def print_kv(title: str, rows: List[Tuple[str, str]]) -> None:
    print(title)
    print("-" * len(title))
    for k, v in rows:
        print(f"  {k:<20} {v}")


def collect_import_inputs(paths: Iterable[str]) -> List[Path]:
    files: List[Path] = []
    for raw in paths:
        p = Path(raw).expanduser()
        if not p.is_absolute():
            p = (Path.cwd() / p).resolve()
        if p.is_dir():
            files.extend(sorted([x for x in p.rglob("*") if x.is_file()]))
        elif p.is_file():
            files.append(p)
    return files


def cmd_source_import(args: argparse.Namespace) -> int:
    files = collect_import_inputs(args.path)
    accepted = 0
    rejected = 0
    warnings: List[str] = []
    produced_ids: List[str] = []
    batch_id = datetime.now(timezone.utc).strftime("batch-%Y%m%d-%H%M%S")

    if not files:
        print("ERR: no files found for import")
        return 2

    for p in files:
        suffix = p.suffix.lower()
        if suffix != ".json":
            rejected += 1
            warnings.append(f"{p}: unsupported format ({suffix or 'no_ext'})")
            continue
        try:
            doc = read_json(p)
        except Exception as exc:
            rejected += 1
            warnings.append(f"{p}: invalid json ({exc})")
            continue
        if doc.get("kind") != "enterprise_governance_source" or doc.get("schema_version") != "v1":
            rejected += 1
            warnings.append(f"{p}: not enterprise_governance_source.v1")
            continue
        sid = str(doc.get("source_id", "")).strip()
        if not sid:
            rejected += 1
            warnings.append(f"{p}: missing source_id")
            continue
        dst = SOURCES_DIR / source_filename(sid)
        write_json(dst, doc)
        accepted += 1
        produced_ids.append(sid)

    print_kv(
        "Source import",
        [
            ("Batch id", batch_id),
            ("Files read", str(len(files))),
            ("Accepted", str(accepted)),
            ("Rejected", str(rejected)),
        ],
    )
    if produced_ids:
        print("\nProduced source IDs")
        for sid in produced_ids:
            print(f"  - {sid}")
    if warnings:
        print("\nWarnings")
        for w in warnings:
            print(f"  - {w}")
    return 0 if accepted > 0 else 3


def cmd_source_list(_: argparse.Namespace) -> int:
    rows = list_sources()
    print("Sources")
    print("-------")
    print(f"{'Source id':<42} {'Format':<20} {'Status':<12} {'Owner':<20}")
    for r in rows:
        owner = str(r.doc.get("owner", {}).get("organization_id", "-"))
        print(
            f"{str(r.doc.get('source_id','-')):<42} "
            f"{str(r.doc.get('source_format','-')):<20} "
            f"{str(r.doc.get('ingestion_status','-')):<12} "
            f"{owner:<20}"
        )
    print(f"\n  Count             {len(rows)}")
    return 0


def cmd_source_inspect(args: argparse.Namespace) -> int:
    rec = find_source_by_id(args.source_id)
    if not rec:
        print(f"ERR: source not found: {args.source_id}", file=sys.stderr)
        return 3
    d = rec.doc
    print_kv(
        "Source inspect",
        [
            ("Source id", str(d.get("source_id", "—"))),
            ("Source type", str(d.get("source_type", "—"))),
            ("Title", str(d.get("title", "—"))),
            ("Owner", str(d.get("owner", {}).get("organization_id", "—"))),
            ("Declared intent", str(d.get("declared_intent", "—"))),
            ("Domain targets", ",".join(d.get("domain_targets", []) or ["—"])),
            ("Specializations", ",".join(d.get("specialization_targets", []) or ["—"])),
            ("Source format", str(d.get("source_format", "—"))),
            ("Payload ref", str(d.get("source_payload_ref", "—"))),
            ("Ingestion status", str(d.get("ingestion_status", "—"))),
            ("Manifest", str(rec.path.relative_to(ROOT))),
        ],
    )
    return 0


def cmd_parse(args: argparse.Namespace) -> int:
    rec = find_source_by_id(args.source_id)
    if not rec:
        print(f"ERR: source not found: {args.source_id}", file=sys.stderr)
        return 3
    rc = call_engine("parse", "--source", str(rec.path))
    if rc != 0:
        return rc
    row = find_parsed_by_source_ref(args.source_id)
    if not row:
        print("ERR: parsed artifact not found after parse", file=sys.stderr)
        return 4
    d = row["doc"]
    c = d.get("coverage_summary", {})
    print_kv(
        "Parse result",
        [
            ("Source ref", str(d.get("source_ref", "—"))),
            ("Parsed facts", str(len(d.get("facts", [])))),
            ("Unknown types", str(c.get("unknown_fact_types", 0))),
            ("Invalid items", str(len(d.get("invalid_items", [])))),
            ("Warnings", str(len(d.get("source_warnings", [])))),
            ("Parsed file", str(row["path"].relative_to(ROOT))),
        ],
    )
    return 0


def cmd_parsed_list(_: argparse.Namespace) -> int:
    rows = list_parsed()
    print("Parsed artifacts")
    print("----------------")
    print(f"{'Parsed id':<42} {'Facts':<8} {'Unresolved':<10} {'Invalid':<8}")
    for row in rows:
        d = row["doc"]
        print(
            f"{str(d.get('source_ref','-')):<42} "
            f"{len(d.get('facts', [])):<8} "
            f"{len(d.get('unresolved_items', [])):<10} "
            f"{len(d.get('invalid_items', [])):<8}"
        )
    print(f"\n  Count             {len(rows)}")
    return 0


