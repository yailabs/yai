#!/usr/bin/env bash
set -euo pipefail

SOCK="${YAI_RUNTIME_INGRESS:-$HOME/.yai/run/control.sock}"
WS="${YAI_WS:-system}"
TRACE="${YAI_TRACE_ID:-cli}"

usage() {
  cat <<'USAGE'
yai-ctl - runtime control-call CLI wrapper

Usage:
  yai-ctl call <command_id> [args...]
  yai-ctl --ws <workspace_id> call <command_id> [args...]
  yai-ctl --socket <path> --ws <workspace_id> call <command_id> [args...]

Examples:
  yai-ctl call yai.workspace.current
  yai-ctl --ws system call yai.workspace.set demo_ws
  yai-ctl --ws demo_ws call yai.workspace.run payment.authorize provider=bank amount=125 authority=reviewer
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --socket)
      SOCK="$2"; shift 2 ;;
    --ws)
      WS="$2"; shift 2 ;;
    --trace)
      TRACE="$2"; shift 2 ;;
    -h|--help)
      usage; exit 0 ;;
    call)
      shift
      break ;;
    *)
      echo "unknown option: $1" >&2
      usage
      exit 2 ;;
  esac
done

if [[ $# -lt 1 ]]; then
  echo "missing command_id" >&2
  usage
  exit 2
fi

CMD_ID="$1"
shift

python3 - "$SOCK" "$WS" "$TRACE" "$CMD_ID" "$@" <<'PY'
import json
import socket
import struct
import sys

sock_path = sys.argv[1]
workspace_id = sys.argv[2]
trace_id = sys.argv[3]
command_id = sys.argv[4]
argv = sys.argv[5:]

MAG = 0x59414950
VER = 1
CMD_HANDSHAKE = 0x0102
CMD_CONTROL_CALL = 0x0105
ENV_FMT = "<II36s36sIHBBII"
REQ_FMT = "<II32s"

def frame(cmd_id, ws_id, payload, trace):
    ws = ws_id.encode("utf-8")[:36].ljust(36, b"\0")
    tr = trace.encode("utf-8")[:36].ljust(36, b"\0")
    env = struct.pack(ENV_FMT, MAG, VER, ws, tr, cmd_id, 2, 1, 0, len(payload), 0)
    return env + payload

def recv_exact(sock, n):
    out = b""
    while len(out) < n:
        chunk = sock.recv(n - len(out))
        if not chunk:
            raise RuntimeError("eof")
        out += chunk
    return out

s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.connect(sock_path)

hs_payload = struct.pack(REQ_FMT, VER, 0, b"yai-ctl")
s.sendall(frame(CMD_HANDSHAKE, workspace_id, hs_payload, trace_id + "-hs"))
env = recv_exact(s, 96)
_, _, _, _, cmd, _, _, _, plen, _ = struct.unpack(ENV_FMT, env)
if cmd != CMD_HANDSHAKE:
    raise RuntimeError("bad_handshake_reply")
_ = recv_exact(s, plen)

payload = json.dumps({
    "type": "yai.control.call.v1",
    "command_id": command_id,
    "target_plane": "runtime",
    "argv": argv,
}).encode("utf-8")

s.sendall(frame(CMD_CONTROL_CALL, workspace_id, payload, trace_id))
env = recv_exact(s, 96)
_, _, _, _, cmd, _, _, _, plen, _ = struct.unpack(ENV_FMT, env)
if cmd != CMD_CONTROL_CALL:
    raise RuntimeError("bad_control_reply")
body = recv_exact(s, plen).decode("utf-8")
s.close()

obj = json.loads(body)
print(json.dumps(obj, ensure_ascii=False, separators=(",", ":")))
PY
