{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai-governance:contracts/control/schema/authority.v1.json",
  "title": "YAI Authority Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "role",
    "arming",
    "ws_id",
    "scope"
  ],
  "properties": {
    "type": {
      "const": "yai.authority.v1"
    },
    "role": {
      "type": "string",
      "enum": [
        "none",
        "user",
        "operator",
        "system"
      ]
    },
    "arming": {
      "type": "boolean"
    },
    "ws_id": {
      "type": "string",
      "maxLength": 64,
      "pattern": "^[a-zA-Z0-9._:-]+$"
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effect_out",
        "control_call"
      ],
      "properties": {
        "effect_out": {
          "type": "string",
          "enum": [
            "deny",
            "allow",
            "quarantine"
          ]
        },
        "control_call": {
          "type": "string",
          "enum": [
            "deny",
            "allow"
          ]
        },
        "break_glass": {
          "type": "boolean"
        }
      }
    },
    "token": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "issuer": {
          "type": "string",
          "maxLength": 64
        },
        "subject": {
          "type": "string",
          "maxLength": 64
        },
        "issued_at": {
          "type": "integer",
          "minimum": 0
        },
        "ttl_secs": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
