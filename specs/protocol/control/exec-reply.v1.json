{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai-governance:protocol/control/exec_reply.v1.json",
  "title": "YAI Exec Reply v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type"
  ],
  "oneOf": [
    {
      "required": [
        "status",
        "code",
        "reason",
        "summary",
        "command_id",
        "target_plane",
        "trace_id"
      ]
    },
    {
      "required": [
        "outcome",
        "code",
        "summary",
        "hint",
        "data",
        "trace",
        "meta"
      ]
    }
  ],
  "properties": {
    "type": {
      "const": "yai.exec.reply.v1"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "ok",
        "warn",
        "deny",
        "fail"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error",
        "nyi"
      ]
    },
    "code": {
      "type": "string",
      "enum": [
        "OK",
        "NOT_IMPLEMENTED",
        "BAD_ARGS",
        "UNAUTHORIZED",
        "DENIED",
        "INVALID_TARGET",
        "RUNTIME_NOT_READY",
        "SERVER_UNAVAILABLE",
        "PROTOCOL_ERROR",
        "INTERNAL_ERROR",
        "NOT_FOUND",
        "CONFLICT",
        "INVALID_STATE"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "hint": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      }
    },
    "hints": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 256
      }
    },
    "command_id": {
      "type": "string",
      "pattern": "^yai\\.[a-z0-9_\\-]+\\.[a-z0-9_\\-]+$"
    },
    "target_plane": {
      "type": "string",
      "enum": [
        "core",
        "exec",
        "knowledge",
        "ingress",
        "brain",
        "mind"
      ]
    },
    "trace_id": {
      "type": "string",
      "maxLength": 128
    },
    "data": {
      "type": "object",
      "additionalProperties": true
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trace_id": {
          "type": "string",
          "maxLength": 128
        },
        "claim_id": {
          "type": "string",
          "maxLength": 128
        },
        "workspace_id": {
          "type": "string",
          "maxLength": 128
        },
        "law_ref": {
          "type": "string",
          "maxLength": 256
        },
        "evidence_ref": {
          "type": "string",
          "maxLength": 256
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "ts": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "target_plane": {
          "type": "string",
          "enum": [
            "core",
            "exec",
            "knowledge",
            "ingress",
            "brain",
            "mind"
          ]
        },
        "command_id": {
          "type": "string",
          "pattern": "^yai\\.[a-z0-9_\\-]+\\.[a-z0-9_\\-]+$"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "decision_record_path": {
          "type": "string",
          "maxLength": 512
        },
        "evidence_index_path": {
          "type": "string",
          "maxLength": 512
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "ok"
          }
        }
      },
      "then": {
        "properties": {
          "code": {
            "const": "OK"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "nyi"
          }
        }
      },
      "then": {
        "properties": {
          "code": {
            "const": "NOT_IMPLEMENTED"
          }
        }
      }
    }
  ]
}
