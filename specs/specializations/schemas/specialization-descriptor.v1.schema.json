{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai.governance.specializations.specialization-descriptor.v1",
  "title": "Specialization Descriptor v1",
  "type": "object",
  "required": [
    "kind",
    "version",
    "specialization_id",
    "canonical_name",
    "family",
    "status",
    "runtime",
    "composition"
  ],
  "properties": {
    "kind": { "const": "specialization_descriptor.v1" },
    "version": { "const": "v1" },
    "specialization_id": { "type": "string", "minLength": 1 },
    "canonical_name": { "type": "string", "minLength": 1 },
    "family": { "type": "string", "minLength": 1 },
    "specialization_class": { "type": "string" },
    "status": { "type": "string", "minLength": 1 },
    "review_state": { "type": "string" },
    "verticalization_wave": { "type": "string" },
    "runtime": {
      "type": "object",
      "required": ["manifest_ref", "bundle_ref"],
      "properties": {
        "manifest_ref": { "type": "string", "minLength": 1 },
        "bundle_ref": { "type": "string", "minLength": 1 },
        "scenario_classes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "composition": {
      "type": "object",
      "properties": {
        "model_refs": { "type": "array", "items": { "type": "string" } },
        "policy_refs": { "type": "array", "items": { "type": "string" } },
        "evidence_refs": { "type": "array", "items": { "type": "string" } },
        "authority_refs": { "type": "array", "items": { "type": "string" } },
        "discovery_refs": { "type": "array", "items": { "type": "string" } },
        "scenario_refs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "taxonomy": { "type": "object" },
    "source": { "type": "object" }
  }
}
