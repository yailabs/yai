{
  "kind": "customer_policy_pack",
  "schema_version": "v1",
  "id": "customer.default.org-workspace-contextual-review",
  "name": "Organization and Workspace Contextual Review Pack",
  "version": "2026.03",
  "scope_targets": {
    "organization_ids": [
      "default-org"
    ],
    "workspace_ids": [
      "ws_ops_review",
      "ws_science_review"
    ],
    "environment_classes": [
      "shared",
      "review"
    ],
    "session_scope": "workspace-bound"
  },
  "domain_targets": [
    "digital",
    "scientific"
  ],
  "family_targets": [
    "digital",
    "scientific"
  ],
  "specialization_targets": [
    "network-egress",
    "remote-publication",
    "parameter-governance",
    "result-publication-control"
  ],
  "compliance_attachments": [
    {
      "compliance_id": "retention-governance",
      "overlay_ref": "packages/regulatory/retention-governance/manifest.v1.json",
      "mode": "required"
    }
  ],
  "overlay_layers": {
    "regulatory": [
      "retention-governance"
    ],
    "sector": [],
    "contextual": [
      "organization",
      "workspace"
    ]
  },
  "authority_profile": {
    "default_scope": "operator",
    "delegated_authority_allowed": true,
    "review_gate_required_for_publish_like_effects": true,
    "escalation_scope": "controller"
  },
  "evidence_profile": {
    "requires_resolution_trace": true,
    "requires_decision_record": true,
    "requires_minimum_provenance_bundle": true,
    "retention_hint": "standard"
  },
  "precedence_mode": "specialization+contextual-overlays+customer-pack",
  "compatibility": {
    "governance_range": ">=0.1.0",
    "runtime_targets": [
      "yai"
    ],
    "export_profiles": [
      "runtime-consumer.v4"
    ]
  },
  "runtime_entrypoint_refs": [
    "indexes/runtime/entrypoints.v1.json#default-runtime"
  ],
  "runtime_entrypoint_ref_fallback": "indexes/runtime/entrypoints.v1.json",
  "export_mode": "runtime-contract",
  "status": "active"
}
