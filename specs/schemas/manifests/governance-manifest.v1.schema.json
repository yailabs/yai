{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "governance/grammar/schema/governance_manifest.v1",
  "title": "governance_manifest.v1",
  "description": "Root governance manifest",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "governance_version": {
      "type": "string"
    },
    "compatibility": {
      "type": "string"
    },
    "foundation_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "domain_index_ref": {
      "type": "string"
    },
    "compliance_index_ref": {
      "type": "string"
    },
    "resolution_entrypoints_ref": {
      "type": "string"
    },
    "export_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "kind",
    "version",
    "governance_version",
    "domain_index_ref",
    "compliance_index_ref"
  ],
  "additionalProperties": true
}
