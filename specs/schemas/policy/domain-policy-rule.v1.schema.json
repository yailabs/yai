{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "governance/grammar/schema/domain_policy_rule.v1",
  "title": "domain_policy_rule.v1",
  "description": "Single domain policy rule",
  "type": "object",
  "properties": {
    "kind": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "rule_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "disabled",
        "deprecated"
      ]
    },
    "scope": {
      "type": "string"
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "effect": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "quarantine",
        "review_required",
        "degrade",
        "require_justification"
      ]
    },
    "priority": {
      "type": "integer"
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "evidence_requirements": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "required": [
    "kind",
    "version",
    "rule_id",
    "status",
    "conditions",
    "effect",
    "priority"
  ],
  "additionalProperties": true
}
