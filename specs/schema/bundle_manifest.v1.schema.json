{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "yai-governance:schema/bundle_manifest.v1.schema.json",
  "title": "YAI Evidence Bundle Manifest v1",
  "type": "object",
  "required": [
    "v",
    "bundle_id",
    "generated_at",
    "artifacts"
  ],
  "properties": {
    "v": {
      "type": "integer",
      "minimum": 1
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "wave_id": {
      "type": "string"
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policy_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role",
          "path",
          "sha256"
        ],
        "properties": {
          "role": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true,
  "description": "Bundle manifest schema for governance evidence bundles across unified runtime artifacts (core/exec/data/graph/knowledge)."
}
